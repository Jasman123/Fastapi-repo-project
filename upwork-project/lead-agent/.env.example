# Required
OPENAI_API_KEY=sk-...

# Scoring — comma separated keywords that = good client fit
SCORE_KEYWORDS=python,api,automation,saas,fastapi,langchain,ai,machine learning
SCORE_THRESHOLD_HOT=70
SCORE_THRESHOLD_WARM=40

# Google Sheets
GOOGLE_SHEETS_CREDENTIALS_PATH=./storage/google_credentials.json
GOOGLE_SHEET_ID=your_sheet_id_here

# Email alerts (Gmail — use App Password not your real password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password
ALERT_RECIPIENT=your@gmail.com

# SQLite
SQLITE_PATH=./storage/leads.db

# App
DEBUG=false
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_MS=15000