# ── LLM Provider ──────────────────────────────────
LLM_PROVIDER=openai          # "openai" | "vertex" | "local"

# ── OpenAI ────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# ── Search ────────────────────────────────────────
TAVILY_API_KEY=tvly-your-key-here   # leave blank → DuckDuckGo fallback

# ── API Security ──────────────────────────────────
API_KEY=dev-key-change-me

# ── GCP / Vertex AI (optional) ────────────────────
GCP_PROJECT=my-gcp-project
GCP_REGION=us-central1
VERTEX_GEN_MODEL=gemini-1.5-flash-002

# Local OpenAI-compatible server (vLLM / llama.cpp)
# Set LLM_PROVIDER=local to use these
LLM_PROVIDER=local
LOCAL_BASE_URL=http://host.docker.internal:8085/v1
LOCAL_MODEL=qwen3
LOCAL_API_KEY=not-needed


# ── Database ──────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./research.db

# ── Agent behaviour ───────────────────────────────
SEARCH_QUERIES_COUNT=4
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048

# ── App ───────────────────────────────────────────
DEBUG=false